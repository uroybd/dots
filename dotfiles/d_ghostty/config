# Appearnce
font-family = "Maple Mono"
font-size = 13
cursor-style = block
cursor-style-blink = true
# theme = "dark:Catppuccin Frappe,light:Catppuccin Latte"
theme = "dark:Kanso Mist,light:Kanso Pearl"
adjust-cell-height = 26%
custom-shader = "./boo-cursor.glsl"

# Window Appearnce
window-padding-x = 3
window-padding-y = 3
window-padding-balance = true
window-decoration = false

# Window Behavior
quit-after-last-window-closed = true
quit-after-last-window-closed-delay = 30s

# Shell
initial-command = "/opt/homebrew/bin/zellij attach -c LCARS"
# command = "/opt/homebrew/bin/nu -e 'quickterm-session'"

# MacOS-specific
macos-option-as-alt=left
# macos-titlebar-style=hidden

# Clipboard
clipboard-read=allow
clipboard-write=allow
copy-on-select=true

# Quick Terminal
quick-terminal-position = right
quick-terminal-size = 25%
quick-terminal-screen = mouse

# Keybindings
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = global:cmd+backquote=toggle_quick_terminal
